{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "email": { ".validate": "newData.isString()" },
        "role": { ".validate": "newData.val() === 'user' || newData.val() === 'caregiver'" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },
    "userSettings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "customVocab": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "items": {
          "$idx": {
            ".validate": "newData.hasChildren(['id', 'word', 'category'])",
            "id": { ".validate": "newData.isString()" },
            "word": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100" },
            "category": { ".validate": "newData.val() === 'noun' || newData.val() === 'verb' || newData.val() === 'adjective' || newData.val() === 'social' || newData.val() === 'important' || newData.val() === 'misc' || newData.val() === 'pronoun'" },
            "source": { ".validate": "newData.isString()" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "updatedAt": { ".validate": "newData.isNumber()" }
          }
        },
        "deletedIds": {
          "$id": { ".validate": "newData.isNumber()" }
        }
      }
    },
    "vocabRequests": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$term": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "userSync": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "lastActivity": { ".validate": "newData.isString()" }
      }
    },
    "userLogs": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$logId": {
          ".validate": "newData.hasChildren(['action', 'timestamp']) && newData.numChildren() <= 15",
          "action": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "level": { ".validate": "newData.isString() && newData.val().length <= 10" },
          "sessionId": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "targetUserId": { ".validate": "newData.isString() && newData.val().length <= 128" },
          "carerId": { ".validate": "newData.isString() && newData.val().length <= 128" },
          "synced": { ".validate": "newData.isBoolean()" },
          "syncTimestamp": { ".validate": "true" },
          "serverTimestamp": { ".validate": "true" },
          "count": { ".validate": "newData.isNumber()" },
          "deviceInfo": { ".validate": "newData.numChildren() <= 5" }
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
