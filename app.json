{
  "expo": {
    "name": "Voice",
    "slug": "ai-powered-aac-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-camera",
      "expo-asset"
    ],
    "assetBundlePatterns": [
      "assets/tf_model/**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Voice uses the camera to identify objects and generate communication suggestions.",
        "NSMicrophoneUsageDescription": "Voice uses the microphone for audio-based communication features.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.elpabloawakens.aipoweredaacapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-icon-background.png",
        "backgroundColor": "#4AADA8"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "package": "com.elpabloawakens.aipoweredaacapp",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "40248271-421a-4a83-bd92-16c7d4767eef"
      }
    }
  }
}
