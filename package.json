{
  "name": "ai-powered-aac-app",
  "version": "1.2.0",
  "private": true,
  "license": "0BSD",
  "main": "index.js",
  "scripts": {
    "start": "npx expo start",
    "start:devclient": "expo start --dev-client",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "clean": "npx rimraf node_modules package-lock.json && npm install",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "eas:build:android": "npx eas build --profile development --platform android",
    "eas:build:android:preview": "npx eas build --profile preview --platform android",
    "eas:build:android:production": "npx eas build --profile production --platform android",
    "eas:submit:android": "npx eas submit --platform android",
    "eas:build:ios": "npx eas build --profile development --platform ios",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-picker/picker": "^2.11.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/stack": "^7.1.1",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.16.0",
    "@tensorflow/tfjs-backend-cpu": "4.16.0",
    "@tensorflow/tfjs-backend-wasm": "4.16.0",
    "@tensorflow/tfjs-backend-webgl": "4.16.0",
    "@tensorflow/tfjs-converter": "4.16.0",
    "@tensorflow/tfjs-core": "4.16.0",
    "@tensorflow/tfjs-data": "4.16.0",
    "@tensorflow/tfjs-layers": "4.16.0",
    "@tensorflow/tfjs-react-native": "1.0.0",
    "an-array-of-english-words": "^2.0.0",
    "axios": "^1.7.9",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-gl": "~16.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^11.4.0",
    "idb": "7.1.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "googleapis": "^171.4.0",
    "http-server": "^14.1.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|firebase|@firebase)"
    ]
  },
  "overrides": {
    "@tensorflow/tfjs-core": "4.16.0",
    "@tensorflow/tfjs-layers": "4.16.0",
    "@tensorflow/tfjs-data": "4.16.0",
    "@tensorflow/tfjs-converter": "4.16.0",
    "@tensorflow/tfjs-backend-cpu": "4.16.0",
    "@tensorflow/tfjs-backend-webgl": "4.16.0",
    "@tensorflow/tfjs-backend-wasm": "4.16.0"
  }
}
